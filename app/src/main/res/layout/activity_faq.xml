<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/backgr"
    android:fitsSystemWindows="true"
    android:paddingTop="24dp"
    android:paddingBottom="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:gravity="center_horizontal">


        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FAQ - Câu hỏi thường gặp"
            android:textColor="@android:color/white"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_faq_card"
            android:padding="16dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔋 Ứng dụng dừng phát âm thanh đột ngột?"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Vui lòng cấp quyền 'Không giới hạn pin' hoặc tắt tối ưu hóa pin cho ứng dụng trong Cài đặt > Pin. Điều này giúp ứng dụng không bị tắt khi chạy nền."
                android:textColor="#B0BEC5"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnGoToSettings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MỞ CÀI ĐẶT"
                android:textAllCaps="true"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:backgroundTint="#0D1B3E"
                android:layout_marginTop="12dp"
                android:layout_gravity="end" />
        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_faq_card"
            android:padding="16dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💾 Làm sao để lưu âm thanh tùy chỉnh?"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Khi ở màn hình tùy chỉnh, nhấn vào biểu tượng 🔊 hoặc nút 'Lưu' ở góc phải để lưu lại bản mix yêu thích của bạn."
                android:textColor="#B0BEC5"
                android:textSize="14sp" />
        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_faq_card"
            android:padding="16dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏸ Làm sao để tắt âm thanh?"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Bạn chỉ cần nhấn vào nút ⏸ (pause) để tạm dừng hoặc ngắt âm thanh đang phát."
                android:textColor="#B0BEC5"
                android:textSize="14sp" />
        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_faq_card"
            android:padding="16dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎧 Có thể nghe offline không?"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Bạn hoàn toàn có thể nghe âm thanh ngoại tuyến nếu đã lưu bản mix trước đó. Không cần kết nối internet."
                android:textColor="#B0BEC5"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
